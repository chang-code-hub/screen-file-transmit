<Window x:Class="screen_file_receiver.ScreenshotToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="截图工具"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Width="600"
        Height="70"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Margin="5">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BtnSelectWindow"
                    Content="选择窗口 (Ctrl+F2)"
                    Width="110"
                    Height="24"
                    Margin="3,0"
                    Click="BtnSelectWindow_Click" />
            <Button x:Name="BtnSelectRegion"
                    Content="选择区域 (Ctrl+F3)"
                    Width="110"
                    Height="24"
                    Margin="3,0"
                    Click="BtnSelectRegion_Click" />
            <Button x:Name="BtnCapture"
                    Content="截图 (Ctrl+F4)"
                    Width="95"
                    Height="24"
                    Margin="3,0"
                    Click="BtnCapture_Click" />
            <Button x:Name="BtnDecodeTest"
                    Content="解码测试 (Ctrl+F5)"
                    Width="110"
                    Height="24"
                    Margin="3,0"
                    Click="BtnDecodeTest_Click" />
            <Button x:Name="BtnCancelSelection"
                    Content="取消选择 (Ctrl+F6)"
                    Width="110"
                    Height="24"
                    Margin="3,0"
                    Click="BtnCancelSelection_Click" />
        </StackPanel>
    </Border>
</Window>