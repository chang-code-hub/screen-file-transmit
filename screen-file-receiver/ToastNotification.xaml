<Window
    x:Class="screen_file_receiver.ToastNotification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="320"
    AllowsTransparency="True"
    Background="Transparent"
    Deactivated="Window_Deactivated"
    Loaded="Window_Loaded"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None"
    SizeToContent="Height"
    MinWidth="320"
    MaxWidth="320">
    <Border
        Margin="10"
        Background="White"
        BorderBrush="#E0E0E0"
        BorderThickness="1"
        CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="12"
                Direction="270"
                Opacity="0.8"
                ShadowDepth="4"
                Color="#33000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header with icon and title  -->
            <StackPanel
                Grid.Row="0"
                Margin="16,12,16,0"
                Orientation="Horizontal">
                <Ellipse
                    x:Name="IconEllipse"
                    Width="20"
                    Height="20"
                    Margin="0,0,8,0"
                    Fill="#52C41A" />
                <TextBlock
                    x:Name="TitleText"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#262626"
                    Text="TITLE" />
            </StackPanel>

            <!--  Message  -->
            <TextBlock
                x:Name="MessageText"
                Grid.Row="1"
                MaxWidth="280"
                Margin="16,8,16,12"
                FontSize="12"
                Foreground="#595959"
                Text="MESSAGE"
                TextWrapping="Wrap" />

            <!--  Countdown progress bar  -->
            <Grid Grid.Row="2" Height="3">
                <Border Background="Transparent" CornerRadius="0,0,8,8" />
                <Rectangle
                    x:Name="CountdownIndicator"
                    Width="320"
                    HorizontalAlignment="Left"
                    Fill="#52C41A" />
            </Grid>
        </Grid>
    </Border>
</Window>
