<Window
    x:Class="screen_file_receiver.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:screen_file_receiver"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Screen File Reader"
    Width="650"
    Height="460"
    MinWidth="500"
    MinHeight="400"
    AllowDrop="True"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  File List  -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label VerticalAlignment="Top" Content="Image Files:" />
            <Border
                Grid.Column="1"
                BorderBrush="Gray"
                BorderThickness="1">
                <ListBox
                    x:Name="FileListBox"
                    Height="120"
                    ItemsSource="{Binding SelectedFiles}"
                    SelectedIndex="{Binding SelectedFileIndex}" />
            </Border>
            <StackPanel
                Grid.Column="2"
                Margin="5,0,0,0"
                VerticalAlignment="Top">
                <Button
                    Width="80"
                    Margin="0,0,0,5"
                    Command="{Binding AddFileCommand}"
                    Content="Add..." />
                <Button
                    Width="80"
                    Margin="0,0,0,5"
                    Command="{Binding RemoveFileCommand}"
                    Content="Remove" />
                <Button
                    Width="80"
                    Command="{Binding ClearFilesCommand}"
                    Content="Clear" />
            </StackPanel>
        </Grid>

        <!--  Preview  -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label VerticalAlignment="Center" Content="Preview:" />
            <Border
                Grid.Column="1"
                Width="128"
                Height="128"
                BorderBrush="Gray"
                BorderThickness="1"
                Background="LightGray">
                <Image
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Source="{Binding PreviewImage}"
                    Stretch="Uniform" />
            </Border>
            <TextBlock
                Grid.Column="2"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                TextWrapping="Wrap"
                Foreground="Gray"
                Text="提示：可以直接将图片文件拖放到窗口中进行添加。" />
        </Grid>

        <!--  Password  -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" VerticalAlignment="Center" Content="Password:" />
            <PasswordBox x:Name="PasswordBox" Grid.Column="1" VerticalContentAlignment="Center" />
        </Grid>

        <!--  Status  -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,5"
                Text="{Binding StatusText}" />
            <ProgressBar
                Grid.Row="1"
                Height="16"
                Maximum="{Binding ProgressMaximum}"
                Value="{Binding ProgressValue}" />
        </Grid>

        <!--  Submit Button  -->
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Button
                Width="110"
                Height="24"
                HorizontalAlignment="Center"
                Click="Button_Click"
                Command="{Binding StartCommand}"
                Content="Start" />
        </Grid>
    </Grid>
</Window>
