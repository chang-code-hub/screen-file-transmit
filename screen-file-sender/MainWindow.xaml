<Window
    x:Class="screen_file_transmit.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="屏幕文件发送器"
    Width="680"
    MinWidth="680"
    AllowsTransparency="True"
    Closing="Window_Closing"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid x:Name="SettingView" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Banner  -->
            <Border
                Grid.Row="0"
                Margin="0,0,0,15"
                Padding="15,10"
                Background="#2D2D30"
                CornerRadius="4"
                MouseDown="Grid_MouseDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="32" />
                    </Grid.ColumnDefinitions>
                    <Label>
                        <Image
                            Height="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="/icon.ico" />
                    </Label>
                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="屏幕文件发送器" />
                </Grid>
            </Border>

            <!--  File Selection  -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label VerticalAlignment="Center" Content="选择文件：" />
                <TextBox
                    x:Name="FilePathTextBox"
                    Grid.Column="1"
                    Margin="0,0,5,0"
                    VerticalContentAlignment="Center"
                    Text="{Binding FilePath}" />
                <TextBlock
                    Grid.Column="2"
                    MinWidth="80"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Text="{Binding FileSizeStr}" />
                <Button
                    Grid.Column="3"
                    Width="80"
                    Command="{Binding BrowseFileCommand}"
                    Content="浏览..." />
            </Grid>

            <!--  Color Mode Selection  -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="编码比例：" />
                <ComboBox
                    x:Name="ScaleComboBox"
                    Grid.Column="1"
                    VerticalContentAlignment="Center"
                    ItemsSource="{Binding ScaleList}"
                    SelectedValue="{Binding Scale}" />

                <Label
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Content="分辨率：" />
                <ComboBox
                    x:Name="ResolutionComboBox"
                    Grid.Column="3"
                    VerticalContentAlignment="Center"
                    ItemsSource="{Binding ResolutionList}"
                    SelectedItem="{Binding SelectedResolution}" />
            </Grid>


            <!--  Custom Resolution  -->
            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCustomResolution}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="自定义尺寸：" />
                <TextBox
                    Grid.Column="1"
                    VerticalContentAlignment="Center"
                    Text="{Binding CustomWidth}" />
                <Label
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="×" />
                <TextBox
                    Grid.Column="3"
                    VerticalContentAlignment="Center"
                    Text="{Binding CustomHeight}" />
            </Grid>
            <!--  Shrink Settings  -->
            <Grid Grid.Row="4" Margin="0,0,0,10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="宽度收缩：" />
                <TextBox
                    Grid.Column="1"
                    VerticalContentAlignment="Center"
                    Text="{Binding ShrinkWidth}" />
                <Label
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Content="高度收缩：" />
                <TextBox
                    Grid.Column="3"
                    VerticalContentAlignment="Center"
                    Text="{Binding ShrinkHeight}" />
            </Grid>

            <Grid Grid.Row="5" Margin="0,0,0,10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="纠错级别：" />
                <ComboBox
                    Grid.Column="1"
                    VerticalContentAlignment="Center"
                    ItemsSource="{Binding ErrorCorrectionList}"
                    SelectedItem="{Binding ErrorCorrectionPercent}" />
                <Label
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Content="密码：" />
                <PasswordBox
                    x:Name="PasswordBox"
                    Grid.Column="3"
                    VerticalContentAlignment="Center" />
            </Grid>

            <!--  Save Directory  -->
            <Grid Grid.Row="6" Margin="0,0,0,10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label VerticalAlignment="Center" Content="保存路径：" />
                <TextBox
                    Grid.Column="1"
                    Margin="0,0,5,0"
                    VerticalContentAlignment="Center"
                    Text="{Binding SaveDirectory}" />
                <Button
                    Grid.Column="2"
                    Width="80"
                    Margin="0,0,5,0"
                    Command="{Binding BrowseSaveDirectoryCommand}"
                    Content="浏览..." />
                <Button
                    Grid.Column="3"
                    Width="80"
                    Command="{Binding OpenSaveDirectoryCommand}"
                    Content="打开" />
            </Grid>

            <!--  Progress  -->
            <Grid Grid.Row="8" Margin="0,0,0,10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="175" />
                </Grid.ColumnDefinitions>
                <Label>保存进度：</Label>
                <ProgressBar
                    Grid.Column="1"
                    Height="20"
                    Maximum="100"
                    Minimum="0"
                    Value="{Binding ConversionProgress}" />
                <TextBlock
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding ConversionStatus}" />
            </Grid>

            <!--  Submit Button  -->
            <Grid Grid.Row="9" Margin="0,0,0,10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="1"
                    Width="110"
                    Height="24"
                    Click="Button_Click"
                    Command="{Binding SaveToFileCommand}"
                    Content="转换"
                    IsEnabled="{Binding IsConvertButtonEnabled}" />
                <Button
                    Grid.Column="1"
                    Width="110"
                    Height="24"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Visibility="{Binding IsConverting, Converter={StaticResource BoolToVis}}" />
                <Button
                    Grid.Column="3"
                    Width="110"
                    Height="24"
                    Click="Button_Click"
                    Command="{Binding PreviewCommand}"
                    Content="预览"
                    IsEnabled="{Binding IsPreviewButtonEnabled}" />
                <Button
                    Grid.Column="5"
                    Width="110"
                    Height="24"
                    Click="ExitButton_Click"
                    Content="退出" />
            </Grid>

        </Grid>

        <!--  Preview Panel  -->
        <Grid
            x:Name="PreviewView"
            Grid.Row="0"
            Grid.RowSpan="2"
            Margin="5"
            Background="White"
            MouseDown="Grid_MouseDown">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid MouseDown="Grid_MouseDown">
                <StackPanel
                    Margin="5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Width="80"
                        Margin="5,0"
                        Command="{Binding PreviewPreviousPageCommand}"
                        Content="上一页" />
                    <Button
                        Width="80"
                        Margin="5,0"
                        Command="{Binding PreviewNextPageCommand}"
                        Content="下一页" />
                    <Button
                        Width="80"
                        Margin="5,0"
                        Command="{Binding PreviewBackCommand}"
                        Content="返回" />
                    <Button
                        Width="80"
                        Margin="5,0"
                        Click="ExitButton_Click"
                        Content="退出" />
                </StackPanel>
            </Grid>
            <!--<TextBlock
                Grid.Row="1"
                HorizontalAlignment="Center"
                Text="{Binding PreviewInfoText}" />-->
            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Auto"
                PreviewMouseDown="ScrollViewer_PreviewMouseDown"
                VerticalScrollBarVisibility="Auto">
                <Image
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    SnapsToDevicePixels="True"
                    Source="{Binding PreviewImageSource}"
                    Stretch="None"
                    UseLayoutRounding="True" />
            </ScrollViewer>
            <Grid
                Grid.Row="2"
                Panel.ZIndex="1"
                Background="#CCFFFFFF"
                Visibility="{Binding IsPreviewLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical">
                    <ProgressBar
                        Width="480"
                        Height="16"
                        IsIndeterminate="True" />
                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Text="加载中..." />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>