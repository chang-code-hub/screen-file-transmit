<Window
    x:Class="screen_file_transmit.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:screen_file_transmit"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="屏幕文件发送器"
    Width="600"
    ResizeMode="NoResize"
    SizeToContent="Height"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  File Selection  -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label VerticalAlignment="Center" Content="选择文件：" />
            <TextBox
                x:Name="FilePathTextBox"
                Grid.Column="1"
                Margin="0,0,5,0"
                VerticalContentAlignment="Center"
                Text="{Binding FilePath}" />
            <TextBlock
                Grid.Column="2"
                Margin="0,0,10,0"
                MinWidth="80"
                VerticalAlignment="Center"
                Text="{Binding FileSizeStr}" />
            <Button
                Grid.Column="3"
                Width="80"
                Command="{Binding BrowseFileCommand}"
                Content="浏览..." />
        </Grid>

        <!--  Color Mode Selection  -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label
                Grid.Column="0"
                VerticalAlignment="Center"
                Content="编码比例：" />
            <ComboBox
                x:Name="ScaleComboBox"
                Grid.Column="1"
                VerticalContentAlignment="Center"
                ItemsSource="{Binding ScaleList}"
                SelectedValue="{Binding Scale}" />

            <Label
                Grid.Column="2"
                VerticalAlignment="Center"
                Content="分辨率：" />
            <!--<TextBlock Grid.Column="3" VerticalAlignment="Center">
                <Run Text="{Binding ScreenSize.Width}" />
                <Run Text=" * " />
                <Run Text="{Binding ScreenSize.Height}" />
            </TextBlock>-->
            <!--  Resolution Selection  -->

            <ComboBox
                x:Name="ResolutionComboBox"
                Grid.Column="3"
                VerticalContentAlignment="Center"
                ItemsSource="{Binding ResolutionList}"
                SelectedItem="{Binding SelectedResolution}" />
        </Grid>

        <!--  Shrink Settings  -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label
                Grid.Column="0"
                VerticalAlignment="Center"
                Content="宽度收缩：" />
            <TextBox
                Grid.Column="1"
                VerticalContentAlignment="Center"
                Text="{Binding ShrinkWidth}" />
            <Label
                Grid.Column="2"
                VerticalAlignment="Center"
                Content="高度收缩：" />
            <TextBox
                Grid.Column="3"
                VerticalContentAlignment="Center"
                Text="{Binding ShrinkHeight}" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label
                Grid.Column="0"
                VerticalAlignment="Center"
                Content="纠错级别：" />
            <ComboBox
                Grid.Column="1"
                VerticalContentAlignment="Center"
                ItemsSource="{Binding ErrorCorrectionList}"
                SelectedItem="{Binding ErrorCorrectionPercent}" />
            <!--  Password  -->
            <Label Grid.Column="2" VerticalAlignment="Center" Content="密码：" />
            <PasswordBox Grid.Column="3" x:Name="PasswordBox" VerticalContentAlignment="Center" />
        </Grid>

        <!--<Grid  Grid.Row="3"  Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" VerticalAlignment="Center" Content="密码：" />
            <PasswordBox x:Name="PasswordBox" Grid.Column="1" VerticalContentAlignment="Center" />
        </Grid>-->

        <!--  Save Directory  -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label VerticalAlignment="Center" Content="保存路径：" />
            <TextBox
                Grid.Column="1"
                Margin="0,0,5,0"
                VerticalContentAlignment="Center"
                Text="{Binding SaveDirectory}" />
            <Button
                Grid.Column="2"
                Width="80"
                Command="{Binding BrowseSaveDirectoryCommand}"
                Content="浏览..." />
        </Grid>

        <!--  Custom Resolution  -->
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCustomResolution}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label
                Grid.Column="0"
                VerticalAlignment="Center"
                Content="自定义尺寸：" />
            <TextBox
                Grid.Column="1"
                VerticalContentAlignment="Center"
                Text="{Binding CustomWidth}" />
            <Label
                Grid.Column="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="×" />
            <TextBox
                Grid.Column="3"
                VerticalContentAlignment="Center"
                Text="{Binding CustomHeight}" />
        </Grid>

        <!--<Grid Grid.Row="6" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label
                Grid.Column="0"
                VerticalAlignment="Center"
                Content="文件大小：" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Text="{Binding FileSizeStr}" />
            -->
        <!--<Label
                Grid.Column="2"
                VerticalAlignment="Center"
                Content="File Offset:" />-->
        <!--<TextBox
                Grid.Column="3"
                VerticalContentAlignment="Center"
                Text="{Binding FileOffset}" />-->
        <!--
        </Grid>-->
        <!--  Progress  -->
        <Grid Grid.Row="7" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>
            <Label>保存进度：</Label>
            <ProgressBar
                Grid.Column="1"
                Height="20"
                Maximum="100"
                Minimum="0"
                Value="{Binding ConversionProgress}" />
            <TextBlock
                Grid.Column="2"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Text="{Binding ConversionStatus}" />
        </Grid>

        <!--  Submit Button  -->
        <Grid Grid.Row="8" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="1"
                Width="110"
                Height="24"
                Click="Button_Click"
                Command="{Binding SaveToFileCommand}"
                Content="转换..."
                IsEnabled="{Binding IsConvertButtonEnabled}" />
            <Button
                Grid.Column="3"
                Width="110"
                Height="24"
                Command="{Binding CancelCommand}"
                Content="取消"
                IsEnabled="{Binding IsConverting}" />
            <Button
                Grid.Column="5"
                Width="110"
                Height="24"
                Click="Button_Click"
                Command="{Binding StartCommand}"
                Content="预览"
                IsEnabled="{Binding IsPreviewButtonEnabled}" />
        </Grid>
    </Grid>
</Window>